{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "A saved contract analysis",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this analysis"
        },
        "title": {
          "type": "string",
          "description": "Title of the contract or analysis"
        },
        "summary": {
          "type": "string",
          "description": "The summary of the contract"
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of identified risks"
        },
        "obligations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of obligations"
        },
        "keyDates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date_or_timeframe": { "type": "string" },
              "event_name": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Key dates in the contract"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the analysis was saved"
        }
      },
      "required": ["userId", "title", "summary", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/Analysis" },
      "description": "Saved contract analyses"
    }
  }
}
